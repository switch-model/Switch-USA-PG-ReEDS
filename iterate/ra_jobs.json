{
    "region": "us-east-2",
    "ce_scenario_list": "in/2030/ce/scenarios_build.ra.txt",
    "ra_scenario_list": "in/2030/ra/scenarios_split.ra.txt",
    "solve_ce": {
        "jobName": "solve-scenarios-ce",
        "jobDefinition": "arn:aws:batch:us-east-2:728904422395:job-definition/switch-solve-scenarios:5",
        "jobQueue": "arn:aws:batch:us-east-2:728904422395:job-queue/solve-ce-ec2-job-queue",
        "arrayProperties": {
            "size": 2
        },
        "ecsPropertiesOverride": {
            "taskProperties": [
                {
                    "containers": [
                        {
                            "name": "switch-solve-scenarios-weekly-container",
                            "command": [
                                "--scenario-list",
                                "in/2030/ce/scenarios_build.ra.txt",
                                "--log-run",
                                "--solver",
                                "gurobi",
                                "--solver-options-string",
                                "method=2 crossover=0",
                                "--exclude-modules",
                                "study_modules.delayed_expressions",
                                "study_modules.nl_solver"
                            ],
                            "resourceRequirements": [
                                {
                                    "type": "VCPU",
                                    "value": "8"
                                },
                                {
                                    "type": "MEMORY",
                                    "value": "61440"
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    },
    "solve_ce_eval": {
        "jobName": "solve-scenarios-ce-eval",
        "jobDefinition": "arn:aws:batch:us-east-2:728904422395:job-definition/switch-solve-scenarios:5",
        "jobQueue": "arn:aws:batch:us-east-2:728904422395:job-queue/solve-ce-ec2-job-queue",
        "arrayProperties": {
            "size": 2
        },
        "ecsPropertiesOverride": {
            "taskProperties": [
                {
                    "containers": [
                        {
                            "name": "switch-solve-scenarios-weekly-container",
                            "command": [
                                "--scenario-list",
                                "in/2030/ce/scenarios_eval.txt",
                                "--log-run",
                                "--solver",
                                "gurobi",
                                "--solver-options-string",
                                "method=2 crossover=0",
                                "--exclude-modules",
                                "study_modules.delayed_expressions",
                                "study_modules.nl_solver"
                            ],
                            "resourceRequirements": [
                                {
                                    "type": "VCPU",
                                    "value": "8"
                                },
                                {
                                    "type": "MEMORY",
                                    "value": "61440"
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    },
    "solve_ra": {
        "jobName": "solve-scenarios-ra",
        "jobDefinition": "arn:aws:batch:us-east-2:728904422395:job-definition/solve-scenarios-fargate:2",
        "jobQueue": "arn:aws:batch:us-east-2:728904422395:job-queue/fargate-us-east-2b-on-demand-job-queue",
        "arrayProperties": {
            "size": 500
        },
        "ecsPropertiesOverride": {
            "taskProperties": [
                {
                    "containers": [
                        {
                            "name": "switch-solve-scenarios-container",
                            "command": [
                                "--scenario-list",
                                "in/2030/ra/scenarios_split.ra.txt"
                            ],
                            "resourceRequirements": [
                                {
                                    "value": "1",
                                    "type": "VCPU"
                                },
                                {
                                    "value": "2048",
                                    "type": "MEMORY"
                                }
                            ],
                            "environment": []
                        }
                    ]
                }
            ]
        },
        "retryStrategy": {
            "attempts": 10
        }
    },
    "ra_add_difficult_timeseries": {
        "jobName": "ra-add-difficult-timeseries",
        "jobDefinition": "arn:aws:batch:us-east-2:728904422395:job-definition/aws-environment-fargate-arm:2",
        "jobQueue": "arn:aws:batch:us-east-2:728904422395:job-queue/fargate-us-east-2b-on-demand-job-queue",
        "ecsPropertiesOverride": {
            "taskProperties": [
                {
                    "containers": [
                        {
                            "command": [
                                "python",
                                "iterate/ra_add_difficult_timeseries.py",
                                "in/2030/ce/scenarios_build.ra.txt",
                                "in/2030/ra/scenarios_split.ra.txt"
                            ],
                            "name": "aws-environment",
                            "resourceRequirements": [
                                {
                                    "value": "4",
                                    "type": "VCPU"
                                },
                                {
                                    "value": "20480",
                                    "type": "MEMORY"
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    },
    "ra_iterate_aws": {
        "jobName": "ra-iterate",
        "jobDefinition": "arn:aws:batch:us-east-2:728904422395:job-definition/aws-environment-fargate-arm:2",
        "jobQueue": "arn:aws:batch:us-east-2:728904422395:job-queue/fargate-us-east-2b-on-demand-job-queue",
        "ecsPropertiesOverride": {
            "taskProperties": [
                {
                    "containers": [
                        {
                            "command": [
                                "python",
                                "iterate/ra_iterate_aws.py"
                            ],
                            "name": "aws-environment",
                            "resourceRequirements": [
                                {
                                    "value": "1",
                                    "type": "VCPU"
                                },
                                {
                                    "value": "2048",
                                    "type": "MEMORY"
                                }
                            ],
                            "environment": []
                        }
                    ]
                }
            ]
        }
    }
}