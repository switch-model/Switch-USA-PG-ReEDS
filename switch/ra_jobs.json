{
    "region": "us-east-2",
    "ce_scenario_list": "in/2030/ce/scenarios_build.ra.txt",
    "solve_ce": {
        "jobName": "solve-scenarios-ce",
        "jobDefinition": "arn:aws:batch:us-east-2:728904422395:job-definition/solve-scenarios-fargate:2",
        "jobQueue": "arn:aws:batch:us-east-2:728904422395:job-queue/fargate-us-east-2b-on-demand-job-queue",
        "arrayProperties": {
            "size": 3
        },
        "ecsPropertiesOverride": {
            "taskProperties": [
                {
                    "containers": [
                        {
                            "resourceRequirements": [
                                {
                                    "type": "VCPU",
                                    "value": "4"
                                },
                                {
                                    "type": "MEMORY",
                                    "value": "32256"
                                }
                            ],
                            "command": [
                                "--scenario-list",
                                "in/2030/ce/scenarios_build.ra.txt",
                                "--log-run"
                            ],
                            "name": "switch-solve-scenarios-weekly-container"
                        }
                    ]
                }
            ]
        }
    },
    "solve_ra": {
        "jobName": "solve-scenarios-ra",
        "jobDefinition": "arn:aws:batch:us-east-2:728904422395:job-definition/solve-scenarios-fargate:2",
        "jobQueue": "arn:aws:batch:us-east-2:728904422395:job-queue/fargate-us-east-2b-on-demand-job-queue",
        "arrayProperties": {
            "size": 500
        },
        "ecsPropertiesOverride": {
            "taskProperties": [
                {
                    "containers": [
                        {
                            "command": [
                                "--scenario-list",
                                "in/2030/ra/scenarios_split.ra.txt"
                            ],
                            "name": "switch-solve-scenarios-weekly-container",
                            "resourceRequirements": [
                                {
                                    "value": "1",
                                    "type": "VCPU"
                                },
                                {
                                    "value": "1024",
                                    "type": "MEMORY"
                                }
                            ],
                            "environment": []
                        }
                    ]
                }
            ]
        },
        "retryStrategy": {
            "attempts": 10
        }
    },
    "ra_add_difficult_timeseries": {
        "jobName": "ra-add-difficult-timeseries",
        "jobDefinition": "arn:aws:batch:us-east-2:728904422395:job-definition/aws-environment-fargate-arm:1",
        "jobQueue": "arn:aws:batch:us-east-2:728904422395:job-queue/fargate-us-east-2b-on-demand-job-queue",
        "ecsPropertiesOverride": {
            "taskProperties": [
                {
                    "containers": [
                        {
                            "command": [
                                "python",
                                "ra_add_difficult_timeseries.py",
                                "in/2030/ce/scenarios_build.ra.txt",
                                "in/2030/ra/scenarios_split.ra.txt"
                            ],
                            "name": "aws-environment",
                            "resourceRequirements": [
                                {
                                    "value": "4",
                                    "type": "VCPU"
                                },
                                {
                                    "value": "32256",
                                    "type": "MEMORY"
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    },
    "ra_iterate_aws": {
        "jobName": "ra-iterate",
        "jobDefinition": "arn:aws:batch:us-east-2:728904422395:job-definition/aws-environment-fargate-arm:1",
        "jobQueue": "arn:aws:batch:us-east-2:728904422395:job-queue/fargate-us-east-2b-on-demand-job-queue",
        "ecsPropertiesOverride": {
            "taskProperties": [
                {
                    "containers": [
                        {
                            "command": [
                                "python",
                                "ra_iterate_aws.py"
                            ],
                            "name": "aws-environment",
                            "resourceRequirements": [
                                {
                                    "value": "1",
                                    "type": "VCPU"
                                },
                                {
                                    "value": "1638",
                                    "type": "MEMORY"
                                }
                            ],
                            "environment": []
                        }
                    ]
                }
            ]
        }
    }
}